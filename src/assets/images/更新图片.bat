@echo off
chcp 65001 >nul
echo ============================================
echo   更新图片资源 - 生成 Base64 编码
echo ============================================
echo.

cd /d "%~dp0\..\..\.."

echo [1/3] 正在生成图片 Base64...
npx tsx scripts/generate-images.ts

if %errorlevel% equ 0 (
    echo.
    echo [2/3] 图片更新成功！
    echo.
    echo [3/3] 正在验证构建...
    npm run build 2>&1 | findstr "built"
    
    if %errorlevel% equ 0 (
        echo.
        echo ============================================
        echo   ✓ 全部完成！图片已更新并验证通过
        echo ============================================
    ) else (
        echo.
        echo ============================================
        echo   ✗ 构建失败，请检查错误信息
        echo ============================================
    )
) else (
    echo.
    echo ============================================
    echo   ✗ 图片生成失败
    echo ============================================
)

echo.
pause